<!-- Envelope intro screen -->
@if (_envelopeVisible)
{
    <div class="env-overlay @(_envelopeOpening ? "env-overlay--fading" : "")" @onclick="OpenEnvelope" role="button" tabindex="0">
        <div class="env-scene">
            <div class="env @(_envelopeOpening ? "env--opening" : "")">
                <!-- envelope body with fold lines -->
                <div class="env-body">
                    <svg viewBox="0 0 400 270" preserveAspectRatio="none" aria-hidden="true">
                        <polygon points="0,270 200,148 400,270"
                                 fill="rgba(45,90,39,0.045)" stroke="rgba(45,90,39,0.20)" stroke-width="0.9"/>
                        <polygon points="0,0 0,270 200,148"
                                 fill="rgba(45,90,39,0.025)" stroke="rgba(45,90,39,0.15)" stroke-width="0.9"/>
                        <polygon points="400,0 400,270 200,148"
                                 fill="rgba(45,90,39,0.025)" stroke="rgba(45,90,39,0.15)" stroke-width="0.9"/>
                    </svg>
                </div>
                <!-- triangular flap — rotates back on open -->
                <div class="env-flap">
                    <svg viewBox="0 0 402 168" preserveAspectRatio="none" aria-hidden="true">
                        <polygon points="0,0 402,0 201,150"
                                 fill="#f5efe6" stroke="#2d5a27" stroke-width="1.5" stroke-linejoin="round"/>
                    </svg>
                </div>
                <!-- wax seal at the junction -->
                <div class="env-seal" aria-hidden="true">
                    <span class="env-seal-text">M ✦ D</span>
                </div>
            </div>
            <p class="env-hint">Click to open</p>
        </div>
    </div>
}

@if (!_envelopeVisible)
{
<main class="hero">
    <div class="hero-content">

        <p class="bismillah" lang="ar" dir="rtl">بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِيْمِ</p>

        <p class="invite-love">We Would love to have you at our</p>
        <h1 class="engagement-word">ENGAGEMENT!</h1>

        <div class="ornament">✦ &nbsp; ✦ &nbsp; ✦</div>

        <div class="names">
            <span class="name">Mazen</span>
            <span class="ampersand">&amp;</span>
            <span class="name">Doha</span>
        </div>

        <img src="couple3.jpg" alt="Mazen & Doha" class="couple-photo" />

        <div class="divider">
            <span class="divider-line"></span>
            <span class="diamond">◆</span>
            <span class="divider-line"></span>
        </div>

        <p class="getting-engaged">are getting engaged</p>

        <div class="countdown">
            <div class="countdown-unit">
                <span class="count">@_days</span>
                <span class="unit-label">Days</span>
            </div>
            <span class="sep">·</span>
            <div class="countdown-unit">
                <span class="count">@_hours.ToString("D2")</span>
                <span class="unit-label">Hours</span>
            </div>
            <span class="sep">·</span>
            <div class="countdown-unit">
                <span class="count">@_minutes.ToString("D2")</span>
                <span class="unit-label">Minutes</span>
            </div>
            <span class="sep">·</span>
            <div class="countdown-unit">
                <span class="count">@_seconds.ToString("D2")</span>
                <span class="unit-label">Seconds</span>
            </div>
        </div>

        <p class="date-line">11 &nbsp;·&nbsp; September &nbsp;·&nbsp; 2026</p>

        <div class="venue">
            <p class="venue-time">AT 7:00 PM</p>
            <p class="venue-name">Villa Le Mariage</p>
            <p class="venue-address">Cortoba Street, King Mariout</p>
            <a class="maps-btn" href="https://maps.google.com/?q=Villa+Le+Mariage+Cortoba+Street+King+Mariout" target="_blank" rel="noopener">
                <svg class="maps-pin" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5S10.62 6.5 12 6.5s2.5 1.12 2.5 2.5S13.38 11.5 12 11.5z"/></svg>
                Open in Google Maps
            </a>
        </div>

        <button class="calendar-btn" @onclick="DownloadCalendar">+ Add to Calendar</button>

        <div class="action-row">
            <button class="rsvp-btn rsvp-btn--outline" @onclick="OpenSongModal">♪ &nbsp; Suggest a Song</button>
            <button class="rsvp-btn rsvp-btn--outline" @onclick="OpenCommentModal">✦ &nbsp; Leave us a comment!</button>
            <button class="rsvp-btn rsvp-btn--outline" @onclick="OpenSigModal">✒ &nbsp; Sign the Guestbook</button>
        </div>

        <!-- ── Inline RSVP (always visible at the bottom) ─────────── -->
        <section class="rsvp-inline" id="rsvp">
            <div class="divider">
                <span class="divider-line"></span>
                <span class="diamond">◆</span>
                <span class="divider-line"></span>
            </div>

            <div class="rsvp-panel">
                @if (_rsvpSubmitted)
                {
                    <div class="thank-you">
                        <p class="ty-ornament">✦</p>
                        <h2>Thank you, @_rsvp.FullName!</h2>
                        @if (_rsvp.Attending == "yes")
                        {
                            <p>We can't wait to celebrate with you ✦</p>
                        }
                        else
                        {
                            <p>You'll be missed — thank you for letting us know.</p>
                        }
                        <button class="rsvp-btn rsvp-btn--outline" @onclick="ResetRsvp" style="margin-top:1.4rem">Send another response</button>
                    </div>
                }
                else
                {
                    <h2 class="modal-title">RSVP</h2>
                    <p class="modal-subtitle">Will you be celebrating with us?</p>

                    <EditForm Model="_rsvp" OnValidSubmit="HandleRsvpSubmit">
                        <DataAnnotationsValidator />

                        <div class="attend-choice">
                            <button type="button"
                                    class="attend-card @(_rsvp.Attending == "yes" ? "is-selected" : "")"
                                    @onclick="@(() => { _rsvp.Attending = "yes"; })">
                                <span class="attend-icon">✓</span>
                                <span class="attend-label">Yes, I'll be there</span>
                            </button>
                            <button type="button"
                                    class="attend-card @(_rsvp.Attending == "no" ? "is-selected" : "")"
                                    @onclick="@(() => { _rsvp.Attending = "no"; })">
                                <span class="attend-icon">♡</span>
                                <span class="attend-label">Can't make it</span>
                            </button>
                        </div>

                        <div class="form-field">
                            <label>Your Name</label>
                            <InputText @bind-Value="_rsvp.FullName" placeholder="Your full name" />
                            <ValidationMessage For="@(() => _rsvp.FullName)" />
                        </div>

                        @if (_rsvp.Attending == "yes")
                        {
                            <div class="form-field">
                                <label>How many of you?</label>
                                <div class="guest-stepper">
                                    <button type="button" class="step-btn" @onclick="DecGuests" disabled="@(_rsvp.GuestCount <= 1)">−</button>
                                    <span class="step-count">@_rsvp.GuestCount</span>
                                    <button type="button" class="step-btn" @onclick="IncGuests" disabled="@(_rsvp.GuestCount >= 2)">+</button>
                                    <span class="step-suffix">@(_rsvp.GuestCount == 1 ? "guest" : "guests")</span>
                                </div>
                            </div>
                        }

                        <div class="form-field">
                            <label>Note <span class="optional">(optional)</span></label>
                            <InputTextArea @bind-Value="_rsvp.Note" placeholder="Anything you'd like us to know…" rows="2" />
                        </div>

                        @if (_rsvpError)
                        {
                            <p class="submit-error">Something went wrong. Please try again.</p>
                        }

                        <button type="submit" class="rsvp-btn submit-btn" disabled="@_rsvpSubmitting">
                            @(_rsvpSubmitting ? "Sending…" : "Send RSVP")
                        </button>
                    </EditForm>
                }
            </div>
        </section>

    </div>
</main>

@if (_songOpen)
{
    <div class="modal-overlay" @onclick="CloseSongModal">
        <div class="modal-box" @onclick:stopPropagation="true">

            @if (_songSubmitted)
            {
                <div class="thank-you">
                    <p class="ty-ornament">♪</p>
                    <p class="song-added-label">"@_song.SongTitle"</p>
                    <p class="song-added-by">by @_song.Artist</p>
                    <p class="song-added-sub">has been added to the playlist ✦</p>
                    <p class="song-added-thanks">Thank you, @_song.GuestName!</p>
                    <button class="rsvp-btn" @onclick="CloseSongModal" style="margin-top:1.8rem">Close</button>
                </div>
            }
            else
            {
                <h2 class="modal-title">♪ &nbsp; Suggest a Song</h2>
                <p class="modal-subtitle">Search for a song to add to our playlist</p>

                <!-- Search group: column-reverse on mobile so results appear above input (above keyboard) -->
                <div class="search-group">
                    <div class="form-field">
                        <label>Search for a Song</label>
                        <div class="search-input-wrap">
                            <input id="song-search-input"
                                   class="search-input"
                                   type="text"
                                   value="@_searchQuery"
                                   placeholder="Song name or artist…"
                                   autocomplete="off"
                                   autocorrect="off"
                                   spellcheck="false" />
                            @if (_isSearching) { <span class="search-spinner">⟳</span> }
                        </div>
                    </div>

                    @if (_searchResults.Count > 0)
                    {
                        <ul class="search-results" id="song-results">
                            @foreach (var r in _searchResults)
                            {
                                <li class="search-result"
                                    @onclick="() => SelectSong(r)"
                                    @ontouchend="() => SelectSong(r)"
                                    @ontouchend:preventDefault="true">
                                    @if (!string.IsNullOrEmpty(r.AlbumArt))
                                    {
                                        <img src="@r.AlbumArt" class="result-art" alt="" />
                                    }
                                    <div class="result-info">
                                        <span class="result-title">@r.Title</span>
                                        <span class="result-artist">@r.Artist</span>
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </div>

                <EditForm Model="_song" OnValidSubmit="HandleSongSubmit">
                    <DataAnnotationsValidator />

                    <div class="form-field">
                        <label>Your Name</label>
                        <InputText @bind-Value="_song.GuestName" placeholder="Your full name" />
                        <ValidationMessage For="@(() => _song.GuestName)" />
                    </div>

                    @if (_selectedResult is not null)
                    {
                        <div class="selected-preview">
                            @if (!string.IsNullOrEmpty(_selectedResult.AlbumArt))
                            {
                                <img src="@_selectedResult.AlbumArt" class="preview-art" alt="" />
                            }
                            <div class="preview-text">
                                <span class="preview-title">@_selectedResult.Title</span>
                                <span class="preview-artist">@_selectedResult.Artist</span>
                            </div>
                            <button type="button" class="preview-clear" @onclick="ClearSong" title="Change song">✕</button>
                        </div>
                    }
                    else
                    {
                        <ValidationMessage For="@(() => _song.SongTitle)" />
                    }

                    <div class="form-field">
                        <label>Why this song? <span class="optional">(optional)</span></label>
                        <InputTextArea @bind-Value="_song.Note" placeholder="Tell us why you love it…" rows="2" />
                    </div>

                    @if (_songError)
                    {
                        <p class="submit-error">Something went wrong. Please try again.</p>
                    }

                    <button type="submit" class="rsvp-btn submit-btn" disabled="@_songSubmitting">
                        @(_songSubmitting ? "Adding…" : "Add to Playlist")
                    </button>
                </EditForm>
            }

        </div>
    </div>
}


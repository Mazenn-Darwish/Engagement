@code {
    private static readonly DateTime EngagementDate = new DateTime(2026, 9, 11, 18, 0, 0, DateTimeKind.Local);

    private int _days, _hours, _minutes, _seconds;
    private CancellationTokenSource _cts = new();

    // ── Envelope intro ────────────────────────────────────
    private bool _envelopeVisible = true;
    private bool _envelopeOpening = false;

    private async Task OpenEnvelope()
    {
        if (_envelopeOpening) return;
        _envelopeOpening = true;
        StateHasChanged();
        await Task.Delay(1750);
        _envelopeVisible = false;
        StateHasChanged();
    }

    // ── RSVP (inline form) ────────────────────────────────
    private bool _rsvpSubmitted;
    private bool _rsvpSubmitting;
    private bool _rsvpError;
    private RsvpModel _rsvp = new();

    // ── Song modal ────────────────────────────────────────
    private bool _songOpen;
    private bool _songSubmitted;
    private bool _songSubmitting;
    private bool _songError;
    private SongModel _song = new();

    private string _searchQuery = "";
    private List<SongSearchResult> _searchResults = [];
    private SongSearchResult? _selectedResult;
    private CancellationTokenSource _searchCts = new();
    private bool _isSearching;
    private DotNetObjectReference<Index>? _dotnetRef;

    // ── Signature / guestbook modal ──────────────────────
    private bool _sigOpen;
    private bool _sigSubmitted;
    private bool _sigSubmitting;
    private bool _sigCanvasReady;
    private string? _sigError;
    private string _sigDataUrl = "";
    private SignatureModel _sig = new();

    private void OpenSigModal()
    {
        _sig            = new SignatureModel();
        _sigSubmitted   = false;
        _sigError       = null;
        _sigCanvasReady = false;
        _sigOpen        = true;
    }

    private void CloseSigModal() => _sigOpen = false;

    private async Task ClearSignature()
    {
        _sigError = null;
        try { await JS.InvokeVoidAsync("clearSignatureCanvas", "sigCanvas"); } catch { }
    }

    private async Task HandleSignatureSubmit()
    {
        bool empty = true;
        try { empty = await JS.InvokeAsync<bool>("isSignatureEmpty", "sigCanvas"); } catch { }

        if (empty)
        {
            _sigError = "Please draw your signature before submitting.";
            return;
        }

        _sigSubmitting = true;
        _sigError      = null;

        try { _sigDataUrl = await JS.InvokeAsync<string>("getSignatureDataUrl", "sigCanvas"); }
        catch { _sigDataUrl = ""; }

        _sig.SignatureData = _sigDataUrl;
        var success = await SignatureService.SubmitAsync(_sig);
        _sigSubmitting = false;

        if (success) _sigSubmitted = true;
        else         _sigError     = "Something went wrong. Please try again.";
    }

    // ── Comment modal ─────────────────────────────────────
    private bool _commentOpen;
    private bool _commentSubmitted;
    private bool _commentSubmitting;
    private bool _commentError;
    private CommentModel _comment = new();
    private List<(string Name, string Message)> _comments = new();

    protected override void OnInitialized()
    {
        UpdateCountdown();
        _ = RunCountdownAsync(_cts.Token);
    }

    private async Task RunCountdownAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        while (!ct.IsCancellationRequested && await timer.WaitForNextTickAsync(ct))
        {
            UpdateCountdown();
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try { await JS.InvokeVoidAsync("initPetals");  } catch { }
            try { await JS.InvokeVoidAsync("hideLoader");  } catch { }
            try { await JS.InvokeVoidAsync("countVisit");  } catch { }
        }
        if (_sigOpen && !_sigCanvasReady)
        {
            _sigCanvasReady = true;
            try { await JS.InvokeVoidAsync("initSignatureCanvas", "sigCanvas"); } catch { }
        }
        if (_songOpen)
        {
            _dotnetRef ??= DotNetObjectReference.Create(this);
            try { await JS.InvokeVoidAsync("initSongSearchInput", _dotnetRef); } catch { }
        }
    }

    private void UpdateCountdown()
    {
        var remaining = EngagementDate - DateTime.Now;
        if (remaining <= TimeSpan.Zero)
            _days = _hours = _minutes = _seconds = 0;
        else
        {
            _days    = (int)remaining.TotalDays;
            _hours   = remaining.Hours;
            _minutes = remaining.Minutes;
            _seconds = remaining.Seconds;
        }
    }

    private void ResetRsvp()
    {
        _rsvp          = new RsvpModel();
        _rsvpSubmitted = false;
        _rsvpError     = false;
    }

    private void IncGuests() { if (_rsvp.GuestCount < 2) _rsvp.GuestCount++; }
    private void DecGuests() { if (_rsvp.GuestCount > 1)  _rsvp.GuestCount--; }

    private async Task HandleRsvpSubmit()
    {
        _rsvpSubmitting = true;
        _rsvpError      = false;
        var success = await RsvpService.SubmitAsync(_rsvp);
        _rsvpSubmitting = false;
        if (success) _rsvpSubmitted = true;
        else         _rsvpError     = true;
    }

    private void OpenSongModal()
    {
        _song           = new SongModel();
        _songSubmitted  = false;
        _songError      = false;
        _searchQuery    = "";
        _searchResults  = [];
        _selectedResult = null;
        _songOpen       = true;
    }

    private void CloseSongModal() => _songOpen = false;

    [JSInvokable]
    public async Task JsSongInput(string value)
    {
        _searchQuery    = value;
        _selectedResult = null;
        _song.SongTitle = "";
        _song.Artist    = "";
        _searchResults  = [];

        _searchCts.Cancel();
        _searchCts = new CancellationTokenSource();
        var cts = _searchCts;

        await InvokeAsync(StateHasChanged);

        if (_searchQuery.Length < 2) return;

        try
        {
            _isSearching = true;
            await InvokeAsync(StateHasChanged);
            await Task.Delay(250, cts.Token);
            cts.Token.ThrowIfCancellationRequested();

            var json = await JS.InvokeAsync<string?>("searchMusic", _searchQuery);
            if (string.IsNullOrEmpty(json)) return;

            var resp = System.Text.Json.JsonSerializer.Deserialize<MusicSearchResp>(json);
            if (resp is { Success: true })
            {
                _searchResults = resp.Results
                    .Where(t => !string.IsNullOrEmpty(t.TrackName))
                    .Select(t => new SongSearchResult(t.TrackName!, t.ArtistName ?? "", t.ArtworkUrl100))
                    .ToList();
            }
        }
        catch (OperationCanceledException) { }
        catch { }
        finally
        {
            _isSearching = false;
            await InvokeAsync(StateHasChanged);
        }
    }


    private void SelectSong(SongSearchResult result)
    {
        _selectedResult  = result;
        _song.SongTitle  = result.Title;
        _song.Artist     = result.Artist;
        _searchResults   = [];
        _searchQuery     = "";
    }

    private void ClearSong()
    {
        _selectedResult  = null;
        _song.SongTitle  = "";
        _song.Artist     = "";
        _searchQuery     = "";
    }

    private async Task HandleSongSubmit()
    {
        _songSubmitting = true;
        _songError      = false;
        var success = await SongService.SubmitAsync(_song);
        _songSubmitting = false;
        if (success) _songSubmitted = true;
        else         _songError     = true;
    }

    private void OpenCommentModal()
    {
        _comment          = new CommentModel();
        _commentSubmitted = false;
        _commentError     = false;
        _commentOpen      = true;
    }

    private void CloseCommentModal() => _commentOpen = false;

    private async Task HandleCommentSubmit()
    {
        _commentSubmitting = true;
        _commentError      = false;
        var success = await CommentService.SubmitAsync(_comment);
        _commentSubmitting = false;
        if (success)
        {
            _comments.Add((_comment.GuestName, _comment.Message));
            _commentSubmitted = true;
        }
        else _commentError = true;
    }

    private async Task DownloadCalendar()
    {
        var nl  = "\r\n";
        var uid = Guid.NewGuid().ToString("N");
        var ics = string.Join(nl,
            "BEGIN:VCALENDAR",
            "VERSION:2.0",
            "PRODID:-//Mazen & Doha//Engagement 2026//EN",
            "CALSCALE:GREGORIAN",
            "METHOD:PUBLISH",
            "BEGIN:VEVENT",
            $"UID:{uid}@mazen-doha-engagement",
            "DTSTART:20260911T190000",
            "DTEND:20260911T230000",
            "SUMMARY:Mazen & Doha — Engagement Party",
            @"DESCRIPTION:Join us to celebrate the engagement of Mazen & Doha!\nVilla Le Mariage\, Cortoba Street\, King Mariout",
            @"LOCATION:Villa Le Mariage\, Cortoba Street\, King Mariout",
            "STATUS:CONFIRMED",
            "END:VEVENT",
            "END:VCALENDAR");
        await JS.InvokeVoidAsync("downloadIcs", ics, "mazen-doha-engagement.ics");
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        _searchCts.Cancel();
        _searchCts.Dispose();
        _dotnetRef?.Dispose();
    }

    private sealed class MusicSearchResp
    {
        [System.Text.Json.Serialization.JsonPropertyName("success")] public bool Success { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("results")] public List<MusicTrack> Results { get; set; } = [];
    }
    private sealed class MusicTrack
    {
        [System.Text.Json.Serialization.JsonPropertyName("trackName")]     public string? TrackName     { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("artistName")]    public string? ArtistName    { get; set; }
        [System.Text.Json.Serialization.JsonPropertyName("artworkUrl100")] public string? ArtworkUrl100 { get; set; }
    }
}

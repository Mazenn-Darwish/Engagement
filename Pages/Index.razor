<!-- Language toggle — always visible, above everything -->
<button class="lang-toggle" @onclick="ToggleLanguage" title="Switch language">
    @(_isAr ? "English" : "عربي")
</button>

<!-- Envelope intro screen -->
@if (_envelopeVisible)
{
    <div class="env-overlay @(_envelopeOpening ? "env-overlay--fading" : "")" @onclick="OpenEnvelope" role="button" tabindex="0">
        <div class="env-scene">
            <div class="env @(_envelopeOpening ? "env--opening" : "")">
                <!-- envelope body with fold lines -->
                <div class="env-body">
                    <svg viewBox="0 0 400 270" preserveAspectRatio="none" aria-hidden="true">
                        <polygon points="0,270 200,148 400,270"
                                 fill="rgba(45,90,39,0.045)" stroke="rgba(45,90,39,0.20)" stroke-width="0.9"/>
                        <polygon points="0,0 0,270 200,148"
                                 fill="rgba(45,90,39,0.025)" stroke="rgba(45,90,39,0.15)" stroke-width="0.9"/>
                        <polygon points="400,0 400,270 200,148"
                                 fill="rgba(45,90,39,0.025)" stroke="rgba(45,90,39,0.15)" stroke-width="0.9"/>
                    </svg>
                </div>
                <!-- triangular flap — rotates back on open -->
                <div class="env-flap">
                    <svg viewBox="0 0 402 168" preserveAspectRatio="none" aria-hidden="true">
                        <polygon points="0,0 402,0 201,150"
                                 fill="#f5efe6" stroke="#2d5a27" stroke-width="1.5" stroke-linejoin="round"/>
                    </svg>
                </div>
                <!-- wax seal at the junction -->
                <div class="env-seal" aria-hidden="true">
                    <span class="env-seal-text">M ✦ D</span>
                </div>
            </div>
            <p class="env-hint" lang="@(_isAr ? "ar" : "en")" dir="@(_isAr ? "rtl" : "ltr")">
                @(_isAr ? "انقر للفتح" : "Click to open")
            </p>
        </div>
    </div>
}

@if (!_envelopeVisible)
{
<main class="hero @(_isAr ? "hero--ar" : "")" dir="@(_isAr ? "rtl" : "ltr")">
    <div class="hero-content">

        <p class="bismillah" lang="ar" dir="rtl">بِسْمِ اللهِ الرَّحْمٰنِ الرَّحِيْمِ</p>

        <p class="invite-love">@T("We Would love to have you at our", "يسعدنا حضوركم في")</p>
        <h1 class="engagement-word">@T("ENGAGEMENT!", "حفل الخطوبة!")</h1>

        <div class="ornament">✦ &nbsp; ✦ &nbsp; ✦</div>

        <div class="names">
            <span class="name">Mazen</span>
            <span class="ampersand">&amp;</span>
            <span class="name">Doha</span>
        </div>

        <img src="couple.jpg" alt="Mazen & Doha" class="couple-photo" />

        <div class="divider">
            <span class="divider-line"></span>
            <span class="diamond">◆</span>
            <span class="divider-line"></span>
        </div>

        <p class="getting-engaged">@T("are getting engaged", "على موعد مع الخطوبة")</p>

        <div class="countdown" dir="ltr">
            <div class="countdown-unit">
                <span class="count">@_days</span>
                <span class="unit-label">@T("Days", "أيام")</span>
            </div>
            <span class="sep">·</span>
            <div class="countdown-unit">
                <span class="count">@_hours.ToString("D2")</span>
                <span class="unit-label">@T("Hours", "ساعات")</span>
            </div>
            <span class="sep">·</span>
            <div class="countdown-unit">
                <span class="count">@_minutes.ToString("D2")</span>
                <span class="unit-label">@T("Minutes", "دقائق")</span>
            </div>
            <span class="sep">·</span>
            <div class="countdown-unit">
                <span class="count">@_seconds.ToString("D2")</span>
                <span class="unit-label">@T("Seconds", "ثواني")</span>
            </div>
        </div>

        <p class="date-line" dir="ltr">11 &nbsp;·&nbsp; @T("September", "سبتمبر") &nbsp;·&nbsp; 2026</p>

        <div class="venue">
            <p class="venue-time">@T("AT 7:00 PM", "الساعة ٧:٠٠ مساءً")</p>
            <p class="venue-name">Villa Le Mariage</p>
            <p class="venue-address" dir="ltr">
                <a href="https://maps.google.com/?q=Villa+Le+Mariage+Cortoba+Street+King+Mariout" target="_blank" rel="noopener">
                    Cortoba Street, King Mariout
                </a>
            </p>
        </div>

        <button class="calendar-btn" @onclick="DownloadCalendar">@T("+ Add to Calendar", "+ أضف للتقويم")</button>

        <div class="action-row">
            <button class="rsvp-btn" @onclick="OpenSongModal">♪ &nbsp; @T("Suggest a Song", "اقترح أغنية")</button>
            <button class="rsvp-btn rsvp-btn--outline" @onclick="OpenCommentModal">✦ &nbsp; @T("Leave us a comment!", "اتركوا تعليقاً!")</button>
        </div>

    </div>
</main>

@if (_songOpen)
{
    <div class="modal-overlay" @onclick="CloseSongModal">
        <div class="modal-box @(_isAr ? "modal-box--ar" : "")" @onclick:stopPropagation="true" dir="@(_isAr ? "rtl" : "ltr")">

            @if (_songSubmitted)
            {
                <div class="thank-you">
                    <p class="ty-ornament">♪</p>
                    <p class="song-added-label">"@_song.SongTitle"</p>
                    <p class="song-added-by">by @_song.Artist</p>
                    <p class="song-added-sub">@T("has been added to the playlist ✦", "تمت الإضافة للقائمة ✦")</p>
                    <p class="song-added-thanks">@T("Thank you", "شكراً")، @_song.GuestName!</p>
                    <button class="rsvp-btn" @onclick="CloseSongModal" style="margin-top:1.8rem">@T("Close", "إغلاق")</button>
                </div>
            }
            else
            {
                <h2 class="modal-title">♪ &nbsp; @T("Suggest a Song", "اقترح أغنية")</h2>
                <p class="modal-subtitle">@T("Search for a song to add to our playlist", "ابحث عن أغنية لقائمتنا")</p>

                <div class="form-field">
                    <label>@T("Search for a Song", "ابحث عن أغنية")</label>
                    <div class="search-input-wrap">
                        <input class="search-input" type="text"
                               value="@_searchQuery"
                               @oninput="OnSearchInput"
                               placeholder="@T("Song name or artist…", "اسم الأغنية أو الفنان...")"
                               autocomplete="off"
                               dir="ltr" />
                        @if (_isSearching) { <span class="search-spinner">⟳</span> }
                    </div>
                </div>

                @if (_searchResults.Count > 0)
                {
                    <ul class="search-results">
                        @foreach (var r in _searchResults)
                        {
                            <li class="search-result" @onclick="() => SelectSong(r)">
                                @if (!string.IsNullOrEmpty(r.AlbumArt))
                                {
                                    <img src="@r.AlbumArt" class="result-art" alt="" />
                                }
                                <div class="result-info">
                                    <span class="result-title">@r.Title</span>
                                    <span class="result-artist">@r.Artist</span>
                                </div>
                            </li>
                        }
                    </ul>
                }

                <EditForm Model="_song" OnValidSubmit="HandleSongSubmit">
                    <DataAnnotationsValidator />

                    <div class="form-field">
                        <label>@T("Your Name", "اسمك")</label>
                        <InputText @bind-Value="_song.GuestName" placeholder="@T("Your full name", "اسمك الكامل")" />
                        <ValidationMessage For="@(() => _song.GuestName)" />
                    </div>

                    @if (_selectedResult is not null)
                    {
                        <div class="selected-preview">
                            @if (!string.IsNullOrEmpty(_selectedResult.AlbumArt))
                            {
                                <img src="@_selectedResult.AlbumArt" class="preview-art" alt="" />
                            }
                            <div class="preview-text">
                                <span class="preview-title">@_selectedResult.Title</span>
                                <span class="preview-artist">@_selectedResult.Artist</span>
                            </div>
                            <button type="button" class="preview-clear" @onclick="ClearSong" title="@T("Change song", "غيّر الأغنية")">✕</button>
                        </div>
                    }
                    else
                    {
                        <ValidationMessage For="@(() => _song.SongTitle)" />
                    }

                    <div class="form-field">
                        <label>@T("Why this song?", "لماذا هذه الأغنية؟") <span class="optional">(@T("optional", "اختياري"))</span></label>
                        <InputTextArea @bind-Value="_song.Note" placeholder="@T("Tell us why you love it…", "أخبرنا لماذا تحبها...")" rows="2" />
                    </div>

                    @if (_songError)
                    {
                        <p class="submit-error">@T("Something went wrong. Please try again.", "حدث خطأ. حاول مجدداً.")</p>
                    }

                    <button type="submit" class="rsvp-btn submit-btn" disabled="@_songSubmitting">
                        @(_songSubmitting ? T("Adding…", "جارٍ الإضافة...") : T("Add to Playlist", "أضف للقائمة"))
                    </button>
                </EditForm>
            }

        </div>
    </div>
}

@if (_commentOpen)
{
    <div class="modal-overlay" @onclick="CloseCommentModal">
        <div class="modal-box @(_isAr ? "modal-box--ar" : "")" @onclick:stopPropagation="true" dir="@(_isAr ? "rtl" : "ltr")">

            @if (_commentSubmitted)
            {
                <div class="thank-you">
                    <p class="ty-ornament">✦</p>
                    <h2>@T("Thank you", "شكراً")، @_comment.GuestName!</h2>
                    <p>@T("Your comment has been noted with love.", "تم تسجيل تعليقك بكل محبة.")</p>
                    <button class="rsvp-btn" @onclick="CloseCommentModal" style="margin-top:1.8rem">@T("Close", "إغلاق")</button>
                </div>
            }
            else
            {
                <h2 class="modal-title">✦ &nbsp; @T("Leave us a comment!", "اتركوا تعليقاً!")</h2>
                <p class="modal-subtitle">@T("A kind word means the world to us", "كلمة طيبة تعني لنا الكثير")</p>

                <EditForm Model="_comment" OnValidSubmit="HandleCommentSubmit">
                    <DataAnnotationsValidator />

                    <div class="form-field">
                        <label>@T("Your Name", "اسمك")</label>
                        <InputText @bind-Value="_comment.GuestName" placeholder="@T("Your full name", "اسمك الكامل")" />
                        <ValidationMessage For="@(() => _comment.GuestName)" />
                    </div>

                    <div class="form-field">
                        <label>@T("Your Comment", "تعليقك")</label>
                        <InputTextArea @bind-Value="_comment.Message" placeholder="@T("Leave Mazen & Doha a message…", "اكتب رسالة لمازن وضحى...")" rows="3" />
                        <ValidationMessage For="@(() => _comment.Message)" />
                    </div>

                    @if (_commentError)
                    {
                        <p class="submit-error">@T("Something went wrong. Please try again.", "حدث خطأ. حاول مجدداً.")</p>
                    }

                    <button type="submit" class="rsvp-btn submit-btn" disabled="@_commentSubmitting">
                        @(_commentSubmitting ? T("Sending…", "جارٍ الإرسال...") : T("Send Comment", "أرسل التعليق"))
                    </button>
                </EditForm>
            }

        </div>
    </div>
}
} @* end @if (!_envelopeVisible) *@


@code {
    private static readonly DateTime EngagementDate = new DateTime(2026, 9, 11, 18, 0, 0, DateTimeKind.Local);

    private int _days, _hours, _minutes, _seconds;
    private CancellationTokenSource _cts = new();

    // ── Envelope intro ────────────────────────────────────
    private bool _envelopeVisible = true;
    private bool _envelopeOpening = false;

    // ── Language toggle ───────────────────────────────────
    private bool _isAr = false;
    private string T(string en, string ar) => _isAr ? ar : en;
    private void ToggleLanguage() => _isAr = !_isAr;

    private async Task OpenEnvelope()
    {
        if (_envelopeOpening) return;
        _envelopeOpening = true;
        StateHasChanged();
        await Task.Delay(1750); // flap opens (0.95s) + overlay fades (0.55s starting at 1.1s) + buffer
        _envelopeVisible = false;
        StateHasChanged();
    }

    // ── Song modal ────────────────────────────────────────
    private bool _songOpen;
    private bool _songSubmitted;
    private bool _songSubmitting;
    private bool _songError;
    private SongModel _song = new();

    private string _searchQuery = "";
    private List<SongSearchResult> _searchResults = [];
    private SongSearchResult? _selectedResult;
    private CancellationTokenSource _searchCts = new();
    private bool _isSearching;

    // ── Comment modal ─────────────────────────────────────
    private bool _commentOpen;
    private bool _commentSubmitted;
    private bool _commentSubmitting;
    private bool _commentError;
    private CommentModel _comment = new();
    private List<(string Name, string Message)> _comments = new();

    protected override void OnInitialized()
    {
        UpdateCountdown();
        _ = RunCountdownAsync(_cts.Token);
    }

    private async Task RunCountdownAsync(CancellationToken ct)
    {
        using var timer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        while (!ct.IsCancellationRequested && await timer.WaitForNextTickAsync(ct))
        {
            UpdateCountdown();
            await InvokeAsync(StateHasChanged);
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender) return;
        try { await JS.InvokeVoidAsync("initPetals"); } catch { /* canvas unavailable */ }
        try { await JS.InvokeVoidAsync("hideLoader");  } catch { /* already removed */  }
    }

    private void UpdateCountdown()
    {
        var remaining = EngagementDate - DateTime.Now;
        if (remaining <= TimeSpan.Zero)
            _days = _hours = _minutes = _seconds = 0;
        else
        {
            _days    = (int)remaining.TotalDays;
            _hours   = remaining.Hours;
            _minutes = remaining.Minutes;
            _seconds = remaining.Seconds;
        }
    }

    private void OpenSongModal()
    {
        _song           = new SongModel();
        _songSubmitted  = false;
        _songError      = false;
        _searchQuery    = "";
        _searchResults  = [];
        _selectedResult = null;
        _songOpen       = true;
    }

    private void CloseSongModal() => _songOpen = false;

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchQuery    = e.Value?.ToString() ?? "";
        _selectedResult = null;
        _song.SongTitle = "";
        _song.Artist    = "";
        _searchResults  = [];

        _searchCts.Cancel();
        _searchCts = new CancellationTokenSource();

        if (_searchQuery.Length < 2) return;

        try
        {
            _isSearching = true;
            await Task.Delay(420, _searchCts.Token);
            _searchResults = await MusicSearch.SearchAsync(_searchQuery);
        }
        catch (OperationCanceledException) { }
        finally { _isSearching = false; }
    }

    private void SelectSong(SongSearchResult result)
    {
        _selectedResult  = result;
        _song.SongTitle  = result.Title;
        _song.Artist     = result.Artist;
        _searchResults   = [];
        _searchQuery     = "";
    }

    private void ClearSong()
    {
        _selectedResult  = null;
        _song.SongTitle  = "";
        _song.Artist     = "";
        _searchQuery     = "";
    }

    private async Task HandleSongSubmit()
    {
        _songSubmitting = true;
        _songError      = false;
        var success = await SongService.SubmitAsync(_song);
        _songSubmitting = false;
        if (success) _songSubmitted = true;
        else         _songError     = true;
    }

    private void OpenCommentModal()
    {
        _comment          = new CommentModel();
        _commentSubmitted = false;
        _commentError     = false;
        _commentOpen      = true;
    }

    private void CloseCommentModal() => _commentOpen = false;

    private async Task HandleCommentSubmit()
    {
        _commentSubmitting = true;
        _commentError      = false;
        var success = await CommentService.SubmitAsync(_comment);
        _commentSubmitting = false;
        if (success)
        {
            _comments.Add((_comment.GuestName, _comment.Message));
            _commentSubmitted = true;
        }
        else _commentError = true;
    }

    private async Task DownloadCalendar()
    {
        var nl  = "\r\n";
        var uid = Guid.NewGuid().ToString("N");
        var ics = string.Join(nl,
            "BEGIN:VCALENDAR",
            "VERSION:2.0",
            "PRODID:-//Mazen & Doha//Engagement 2026//EN",
            "CALSCALE:GREGORIAN",
            "METHOD:PUBLISH",
            "BEGIN:VEVENT",
            $"UID:{uid}@mazen-doha-engagement",
            "DTSTART:20260911T190000",
            "DTEND:20260911T230000",
            "SUMMARY:Mazen & Doha — Engagement Party",
            @"DESCRIPTION:Join us to celebrate the engagement of Mazen & Doha!\nVilla Le Mariage\, Cortoba Street\, King Mariout",
            @"LOCATION:Villa Le Mariage\, Cortoba Street\, King Mariout",
            "STATUS:CONFIRMED",
            "END:VEVENT",
            "END:VCALENDAR");
        await JS.InvokeVoidAsync("downloadIcs", ics, "mazen-doha-engagement.ics");
    }

    public void Dispose()
    {
        _cts.Cancel();
        _cts.Dispose();
        _searchCts.Cancel();
        _searchCts.Dispose();
    }
}
